---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
// Contact page — mirrors the live Squarespace layout: heading + form
// (First/Last name, E-mail, Subject, Message). A static site has no form
// backend: submitting composes an email in the visitor's mail app with all
// fields prefilled. Swap to Formspree/Basin later for silent submission.
---

<BaseLayout title="Contact | CGI & Animation Studio Amsterdam" activePage="contact">
  <style>
    .contact { max-width: 1440px; margin: 0 auto; padding: clamp(56px,9vw,120px) clamp(16px,3vw,56px); display: flex; justify-content: center; }
    .contact-inner { width: 100%; max-width: 840px; }
    .contact h1 {
      color: var(--headline); font-weight: 500; letter-spacing: -0.01em;
      font-size: clamp(26px, 3.4vw, 42px); line-height: 1.15; margin-bottom: 44px;
    }
    .frow { display: flex; gap: 16px; }
    .fgroup { flex: 1; margin-bottom: 22px; }
    .fgroup label { display: block; font-size: 13px; color: var(--body); margin-bottom: 8px; }
    .fgroup label .req { font-size: 11px; color: var(--label); margin-left: 4px; }
    .fgroup input, .fgroup textarea {
      width: 100%; background: #f5f5f5; color: #111; border: 0; border-radius: 2px;
      padding: 13px 12px; font-size: 14px; font-family: inherit;
    }
    .fgroup textarea { min-height: 140px; resize: vertical; }
    .fsend {
      margin-top: 8px; padding: 13px 30px; font-size: 13px; letter-spacing: .02em;
      color: #0a0a0a; background: #ebebeb; border: 0; border-radius: 2px; cursor: pointer;
    }
    .fsend:hover { opacity: .85; }
    .falt { margin-top: 26px; font-size: 12px; color: var(--label); }
    .falt a { color: var(--body); }
    @media (max-width: 640px) { .frow { flex-direction: column; gap: 0; } }
  </style>

  <section class="contact">
    <div class="contact-inner">
      <h1>For projects, collaborations, wholesale inquiries or simply say hello.</h1>
      <form id="cform">
        <span class="fgroup" style="display:block">
          <label>Name <span class="req">(required)</span></label>
          <div class="frow">
            <div class="fgroup"><label for="fn">First Name</label><input id="fn" name="fn" required autocomplete="given-name" /></div>
            <div class="fgroup"><label for="ln">Last Name</label><input id="ln" name="ln" required autocomplete="family-name" /></div>
          </div>
        </span>
        <div class="fgroup"><label for="em">E-mail <span class="req">(required)</span></label><input id="em" name="em" type="email" required autocomplete="email" /></div>
        <div class="fgroup"><label for="su">Subject <span class="req">(required)</span></label><input id="su" name="su" required /></div>
        <div class="fgroup"><label for="ms">Message <span class="req">(required)</span></label><textarea id="ms" name="ms" required></textarea></div>
        <button class="fsend" type="submit">Send</button>
        <p class="falt">Or email directly: <a href="mailto:contact@gast.studio">contact@gast.studio</a></p>
      </form>
    </div>
  </section>

  <script is:inline>
    document.getElementById('cform').addEventListener('submit', function (e) {
      e.preventDefault();
      var v = function (id) { return encodeURIComponent(document.getElementById(id).value); };
      var body = 'Name: ' + v('fn') + '%20' + v('ln') + '%0AEmail: ' + v('em') + '%0A%0A' + v('ms');
      location.href = 'mailto:contact@gast.studio?subject=' + v('su') + '&body=' + body;
    });
  </script>
</BaseLayout>
