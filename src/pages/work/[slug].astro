---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import projects from '../../data/projects.json';

// Data-driven project page. Mirrors the Floyd layout (full-bleed gallery + writeup + pager)
// but is generated from src/data/projects.json so every project shares one template.
//
// Media types in the data (HARD RULE: nothing may reference Squarespace —
// only stored Cloudinary assets, Cloudflare Stream, YouTube, or a flagged gap):
//   'cli'   still  -> stored Cloudinary image (public_id in `id`)
//   'clgif' gif    -> stored Cloudinary animated gif, delivered RAW (free plan blocks gif transforms)
//   'clvid' video  -> stored Cloudinary video (already migrated)
//   'cf'    video  -> Cloudflare Stream embed (already migrated)
//   'yt'    video  -> YouTube embed
//   'miss'  gap    -> media not yet re-uploaded: grey block + original filename in `name`
export function getStaticPaths() {
  return Object.keys((projects as any).projects).map((slug) => ({ params: { slug }, props: { slug } }));
}

const { slug } = Astro.props as { slug: string };
const data = (projects as any).projects[slug];
const order: string[] = (projects as any).order;
const CF_SUB: string = (projects as any).cfSub;

const CL = 'https://res.cloudinary.com/dvyflhlls/';

const clImg = (id: string, w: number) => `${CL}image/upload/f_auto,q_auto,w_${w}/${id}`;
const clSet = (id: string) => [600, 1000, 1600].map((w) => `${clImg(id, w)} ${w}w`).join(', ');
const clVid = (id: string) => `${CL}video/upload/q_auto/f_auto/${id}.mp4`;
const clPoster = (id: string) => `${CL}video/upload/so_0,f_auto,q_auto,w_900/${id}.jpg`;
const ytPoster = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const ytEmbed = (id: string) => `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=1&rel=0&playsinline=1`;
const vimeoEmbed = (id: string) => `https://player.vimeo.com/video/${id}?autoplay=1&muted=1&loop=1`;
const cfPoster = (id: string) => `https://${CF_SUB}/${id}/thumbnails/thumbnail.jpg?height=900`;
const cfEmbed = (id: string) => `https://${CF_SUB}/${id}/iframe?autoplay=true&muted=true&loop=true&controls=false&preload=metadata`;

const ar = (d: string) => { const [w, h] = (d || '16x9').split('x').map(Number); return w && h ? `${w}/${h}` : '16/9'; };
const wRatio = (d: string) => { const [w, h] = (d || '1x1').split('x').map(Number); return w && h ? (w / h).toFixed(4) : '1'; };
const isVideo = (t: string) => t === 'clvid' || t === 'cf' || t === 'yt';

// Group consecutive gallery items into justified blocks; hero videos render as features.
// 'cf' Stream videos (converted gifs) are INLINE gallery tiles, like on the live site.
type Block = { kind: 'grid'; items: any[] } | { kind: 'media'; item: any };
const blocks: Block[] = [];
for (const it of data.items) {
  if (it.t === 'cli' || it.t === 'clgif' || it.t === 'lgif' || it.t === 'cf' || (it.t === 'clvid' && !it.feat) || (it.t === 'miss' && !it.feat)) {
    const last = blocks[blocks.length - 1];
    if (last && last.kind === 'grid') last.items.push(it);
    else blocks.push({ kind: 'grid', items: [it] });
  } else {
    blocks.push({ kind: 'media', item: it });
  }
}

// Build-time HARD-RULE guard: no Squarespace-origin media may remain.
for (const it of data.items) {
  if (it.t === 's' || it.t === 'g' || it.t === 'sqvid') {
    throw new Error(`[${slug}] item still references Squarespace (type '${it.t}'): ${it.u || it.id || ''} — remap it or mark it 'miss'.`);
  }
}

const idx = order.indexOf(slug);
const prevSlug = idx > 0 ? order[idx - 1] : null;
const nextSlug = idx >= 0 && idx < order.length - 1 ? order[idx + 1] : null;
const nameOf = (s: string) => (s === 'floyd' ? 'Floyd' : ((projects as any).projects[s]?.name || s));
---

<BaseLayout title={data.seo || data.name} activePage="work">
  <style>
    .proj { width: 100vw; margin-left: calc(50% - 50vw); }
    .proj-body {
      max-width: 2200px; margin: 0 auto;
      padding: clamp(8px, 2vw, 32px) clamp(10px, 3vw, 56px) 0;
      display: flex; flex-direction: column; gap: 10px;
    }
    /* Feature (video) block: centered, large */
    .feature { display: flex; justify-content: center; }
    .feature-inner { position: relative; width: 100%; max-width: 1180px; overflow: hidden; background: #141414; }
    .feature-inner img, .feature-inner video, .feature-inner iframe {
      position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; border: 0; display: block;
    }
    .feature-inner.is-video video { opacity: 0; transition: opacity .4s ease; }
    .feature-inner.is-video.playing video { opacity: 1; }
    .pending {
      position: absolute; left: 50%; bottom: 14px; transform: translateX(-50%); z-index: 3;
      padding: 5px 11px; font-size: 11px; letter-spacing: .04em; color: #fff;
      background: rgba(0,0,0,.6); border: 1px solid rgba(255,255,255,.25); border-radius: 3px;
    }
    .play {
      position: absolute; inset: 0; z-index: 4; display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,.15); cursor: pointer; border: 0;
    }
    .play svg { width: 64px; height: 64px; opacity: .92; filter: drop-shadow(0 2px 10px rgba(0,0,0,.5)); }

    /* Image gallery block: justified rows in source order (like the live galleries) */
    .pgrid { display: block; }
    .prow { display: flex; gap: 10px; margin-bottom: 10px; }
    .prow:last-child { margin-bottom: 0; }
    .ptile { position: relative; width: 100%; overflow: hidden; background: #141414; line-height: 0; }
    .ptile img, .ptile video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
    .ptile video { opacity: 0; transition: opacity .4s ease; z-index: 1; }
    .ptile.playing video { opacity: 1; }

    /* Missing media: grey block + original filename (media not yet re-uploaded to CDN) */
    .ptile.miss, .feature-inner.miss { background: #1c1c1c; outline: 1px dashed #333; outline-offset: -1px; }
    .miss-name {
      position: absolute; left: 10px; bottom: 9px; z-index: 2; max-width: calc(100% - 20px);
      font: 400 10px/1.4 ui-monospace, Menlo, monospace; color: #555;
      word-break: break-all; white-space: normal;
    }

    .work-writeup { max-width: 2200px; margin: 0 auto; padding: clamp(56px,8vw,130px) clamp(10px,3vw,56px) 0; display: flex; gap: 0; }
    .work-writeup-left { width: var(--left-col); min-width: var(--left-col); display: flex; flex-direction: column; gap: 2px; }
    .work-writeup-text { max-width: 720px; color: var(--body); font-size: 14px; line-height: 1.6; }
    .label { font-size: 11px; line-height: 1.3; color: var(--label); }
    .work-pager { display: flex; justify-content: space-between; align-items: center; max-width: 2200px; margin: 0 auto; padding: clamp(56px,10vw,150px) clamp(10px,3vw,56px); gap: 16px; }
    .pager-link { display: inline-flex; align-items: center; gap: 14px; font-size: clamp(22px,3.6vw,40px); line-height: 1; color: var(--headline); text-decoration: none; transition: opacity .2s; }
    .pager-link.next { margin-left: auto; }
    .pager-link:hover { opacity: .55; }
    .pager-chev { width: .5em; height: .5em; flex: none; }

    @media (max-width: 768px) {
      .pgrid { flex-direction: column; }
      .work-writeup { flex-direction: column; gap: 10px; }
      .work-writeup-left { width: auto; min-width: auto; flex-direction: row; gap: 10px; }
      .pager-link { font-size: 20px; }
    }
  </style>

  <div class="proj">
    <div class="proj-body">
      {blocks.map((b) => b.kind === 'grid' ? (
        <div class="pgrid">
          {b.items.map((m: any) => (
            <div class:list={["ptile", { miss: m.t === 'miss' }]} data-r={wRatio(m.d)} style={`aspect-ratio:${ar(m.d)}`}>
              {m.t === 'cli'
                ? <img src={clImg(m.id, 1000)} srcset={clSet(m.id)} sizes="(max-width:768px) 100vw, 33vw" alt="" decoding="async" loading="lazy" />
                : m.t === 'clgif'
                ? <img src={`${CL}image/upload/${m.id}.gif`} alt="" decoding="async" loading="lazy" />
                : m.t === 'lgif'
                ? <img src={m.id} alt="" decoding="async" loading="lazy" />
                : m.t === 'cf'
                ? <>
                    <img class="poster" src={cfPoster(m.id)} alt="" decoding="async" loading="lazy" />
                    <video muted loop playsinline preload="none" data-hls={`https://${CF_SUB}/${m.id}/manifest/video.m3u8`}></video>
                  </>
                : m.t === 'clvid'
                ? <>
                    <img class="poster" src={clPoster(m.id)} alt="" decoding="async" loading="lazy" />
                    <video muted loop playsinline preload="none" data-mp4={clVid(m.id)}></video>
                  </>
                : <span class="miss-name">{m.name}</span>}
            </div>
          ))}
        </div>
      ) : (
        <div class="feature">
          <div class:list={["feature-inner", { 'is-video': b.item.t === 'clvid', miss: b.item.t === 'miss' }]} style={`aspect-ratio:${ar(b.item.d)}; width:min(1180px, 100%, calc(88vh * ${wRatio(b.item.d)}))`}>
            {b.item.t === 'clvid' && (
              <>
                <img class="poster" src={clPoster(b.item.id)} alt="" decoding="async" loading="lazy" />
                <video muted loop playsinline preload="none" data-src={clVid(b.item.id)}></video>
              </>
            )}
            {b.item.t === 'cf' && (
              <iframe data-embed={cfEmbed(b.item.id)} loading="lazy" allow="autoplay; fullscreen" title={data.name}></iframe>
            )}
            {b.item.t === 'yt' && (
              <button class="play yt" data-embed={ytEmbed(b.item.id)} aria-label="Play video" style={`background-image:url(${ytPoster(b.item.id)});background-size:cover;background-position:center`}>
                <svg viewBox="0 0 68 48" aria-hidden="true"><path d="M66.5 7.7c-.8-2.9-3-5.1-5.9-5.9C55.3.5 34 .5 34 .5S12.7.5 7.4 1.8C4.5 2.6 2.3 4.8 1.5 7.7.2 13 .2 24 .2 24s0 11 1.3 16.3c.8 2.9 3 5.1 5.9 5.9C12.7 47.5 34 47.5 34 47.5s21.3 0 26.6-1.3c2.9-.8 5.1-3 5.9-5.9C67.8 35 67.8 24 67.8 24s0-11-1.3-16.3z" fill="#f00"/><path d="M27 34l18-10-18-10z" fill="#fff"/></svg>
              </button>
            )}
            {b.item.t === 'vimeo' && (
              <iframe data-embed={vimeoEmbed(b.item.id)} loading="lazy" allow="autoplay; fullscreen" title={data.name}></iframe>
            )}
            {b.item.t === 'ig' && (
              <iframe data-embed={b.item.id} loading="lazy" allow="autoplay" title={data.name}></iframe>
            )}
            {b.item.t === 'miss' && (
              <>
                <span class="pending">Video migrating to CDN</span>
                <span class="miss-name">{b.item.name}</span>
              </>
            )}
          </div>
        </div>
      ))}
    </div>

    <section class="work-writeup">
      <div class="work-writeup-left">
        <span class="label">Client: {data.client}</span>
        <span class="label">Concept &amp; CGI: Gast Studio</span>
      </div>
      {data.writeup && <p class="work-writeup-text">{data.writeup}</p>}
    </section>

    <nav class="work-pager">
      {prevSlug && (
        <a class="pager-link prev" href={`/work/${prevSlug}`}>
          <svg class="pager-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 5 8 12 15 19"/></svg>
          {nameOf(prevSlug)}
        </a>
      )}
      {nextSlug && (
        <a class="pager-link next" href={`/work/${nextSlug}`}>
          {nameOf(nextSlug)}
          <svg class="pager-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 5 16 12 9 19"/></svg>
        </a>
      )}
    </nav>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/hls.js@1/dist/hls.min.js"></script>
  <script>
    // Justified rows in source order — mirrors the live Squarespace galleries:
    // every row fills the container width, aspect ratios preserved, no reordering.
    // Target row height adapts to the gallery's median aspect ratio, so pages of
    // small wide gifs pack tight while portrait sets get 2-3 big tiles per row.
    const grids = Array.from(document.querySelectorAll('.pgrid'));
    const tilesArr = grids.map(function (g) { return Array.from(g.querySelectorAll('.ptile')); });
    const GAP = 10;
    function layout() {
      grids.forEach(function (grid, gi) {
        const tiles = tilesArr[gi];
        if (!tiles.length) return;
        const W = grid.clientWidth;
        if (!W) return;
        grid.innerHTML = '';
        const ars = tiles.map(function (t) { return Math.max(0.2, parseFloat(t.dataset.r || '1')); });
        const med = ars.slice().sort(function (a, b) { return a - b; })[Math.floor(ars.length / 2)] || 1;
        const target = Math.max(170, Math.min(600, W / (3.2 * med)));
        let row = [], sum = 0, flushed = 0;
        function flush(isLast) {
          if (!row.length) return;
          const gaps = GAP * (row.length - 1);
          let h = (W - gaps) / sum;
          /* cap a stubby last row — but a single-row gallery always fills the width */
          if (isLast && flushed > 0 && h > target * 1.3) h = target * 1.3;
          flushed++;
          const div = document.createElement('div');
          div.className = 'prow';
          /* inline styles: Astro-scoped CSS can't reach JS-created rows */
          div.style.cssText = 'display:flex;gap:10px;margin-bottom:10px;';
          row.forEach(function (e) {
            e.t.style.width = (h * e.r) + 'px';
            e.t.style.height = h + 'px';
            e.t.style.flex = '0 0 auto';
            div.appendChild(e.t);
          });
          grid.appendChild(div);
          row = []; sum = 0;
        }
        tiles.forEach(function (t, i) {
          row.push({ t: t, r: ars[i] });
          sum += ars[i];
          if (sum * target >= W - GAP * (row.length - 1)) flush(false);
        });
        flush(true);
      });
    }
    layout();
    let rt;
    window.addEventListener('resize', function () { clearTimeout(rt); rt = setTimeout(layout, 150); });

    // Inline Stream tiles: lazy HLS autoplay when in view (like the homepage grid).
    if ('IntersectionObserver' in window) {
      const ioHls = new IntersectionObserver(function (es) {
        es.forEach(function (e) {
          const tile = e.target;
          const v = tile.querySelector('video[data-hls], video[data-mp4]');
          if (!v) return;
          if (e.isIntersecting) {
            if (!v.dataset.started) {
              v.dataset.started = '1';
              if (v.dataset.mp4) {
                v.src = v.dataset.mp4;
              } else {
                const src = v.dataset.hls || '';
                if (window.Hls && window.Hls.isSupported()) {
                  const h = new window.Hls({ autoStartLoad: true, maxBufferLength: 8 });
                  h.loadSource(src); h.attachMedia(v);
                } else {
                  v.src = src;
                }
              }
            }
            const p = v.play(); if (p && p.catch) p.catch(function () {});
            tile.classList.add('playing');
          } else { v.pause(); }
        });
      }, { rootMargin: '350px 0px' });
      document.querySelectorAll('.ptile').forEach(function (t) {
        if (t.querySelector('video[data-hls], video[data-mp4]')) ioHls.observe(t);
      });
    }

    // Cloudinary videos: lazy autoplay when in view.
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(function (es) {
        es.forEach(function (e) {
          const cell = e.target;
          const v = cell.querySelector('video');
          if (!v) return;
          if (e.isIntersecting) {
            if (!v.src) v.src = v.dataset.src || '';
            const p = v.play(); if (p && p.catch) p.catch(function () {});
            cell.classList.add('playing');
          } else { v.pause(); }
        });
      }, { rootMargin: '300px 0px' });
      document.querySelectorAll('.feature-inner.is-video').forEach(function (c) { io.observe(c); });

      // Cloudflare Stream: lazy-mount the iframe when near view.
      const io2 = new IntersectionObserver(function (es) {
        es.forEach(function (e) {
          if (!e.isIntersecting) return;
          const f = e.target;
          if (!f.src) f.src = f.dataset.embed || '';
          io2.unobserve(f);
        });
      }, { rootMargin: '300px 0px' });
      document.querySelectorAll('iframe[data-embed]').forEach(function (f) { io2.observe(f); });
    }

    // YouTube: click-to-load (keeps the page light).
    document.querySelectorAll('button.play.yt').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const wrap = btn.parentElement;
        const f = document.createElement('iframe');
        f.src = btn.dataset.embed || '';
        f.setAttribute('allow', 'autoplay; fullscreen; encrypted-media');
        f.setAttribute('allowfullscreen', '');
        wrap.appendChild(f); btn.remove();
      });
    });
  </script>
</BaseLayout>
