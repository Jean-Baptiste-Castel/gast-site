---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import projects from '../../data/projects.json';

// Projects index — mirrors the live site: 2 columns, big animated covers,
// project title BELOW each cover. Order + covers defined in projects.json.
// Cover types: 'cf' Stream (animated gif thumbnail), 'clgif' raw stored gif,
// 'cli' stored image, 'clvid' Cloudinary video poster.
const order: string[] = (projects as any).order;
const P = (projects as any).projects;
const covers = (projects as any).covers || {};
const CF_SUB: string = (projects as any).cfSub;
const CL = 'https://res.cloudinary.com/dvyflhlls/';

function coverUrl(slug: string): string | null {
  const c = covers[slug];
  if (!c) return null;
  if (c.t === 'cf') return `https://${CF_SUB}/${c.id}/thumbnails/thumbnail.gif?time=2s&duration=4s&width=320&fps=12`;
  if (c.t === 'clgif') return `${CL}image/upload/${c.id}.gif`;
  if (c.t === 'cli') return `${CL}image/upload/f_auto,q_auto,w_1200/${c.id}`;
  if (c.t === 'clvid') return `${CL}video/upload/so_3,f_auto,q_auto,w_1200/${c.id}.jpg`;
  if (c.t === 'vgif') return `${CL}video/upload/du_4,w_800,h_500,c_fill,fps_12/e_loop/${c.id}.gif`;
  if (c.t === 'local') return c.id; /* gif served from this site (no size limit) */
  return null;
}
const nameOf = (s: string) => (s === 'floyd' ? 'Floyd' : (P[s]?.name || s));
// 'cfvid' (Stream) and 'cvvid' (Cloudinary) covers render as real videos,
// cropped by the tile (object-fit cover hides top/bottom), instead of gif thumbs.
const entries = order.map((slug: string) => {
  const c = covers[slug] || {};
  const isVid = c.t === 'cfvid' || c.t === 'cvvid';
  return {
    slug, name: nameOf(slug),
    cover: isVid ? null : coverUrl(slug),
    hls: c.t === 'cfvid' ? `https://${CF_SUB}/${c.id}/manifest/video.m3u8` : null,
    mp4: c.t === 'cvvid' ? `${CL}video/upload/q_auto/f_auto/${c.id}.mp4` : null,
    poster: c.t === 'cfvid' ? `https://${CF_SUB}/${c.id}/thumbnails/thumbnail.jpg?time=1s&width=900`
          : c.t === 'cvvid' ? `${CL}video/upload/so_3,f_auto,q_auto,w_900/${c.id}.jpg` : null,
  };
});
---

<BaseLayout title="CGI & Motion Design Projects | Amsterdam | Gast Studio" activePage="work">
  <style>
    /* full-bleed: escape the 1440px .page container, like the live site */
    .work-index { width: 100vw; margin-left: calc(50% - 50vw); padding: clamp(8px,2vw,40px) clamp(16px,3vw,46px) clamp(56px,8vw,120px); }
    .wgrid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(24px,4vw,64px) clamp(16px,2.4vw,36px); }
    .wcard { display: block; text-decoration: none; }
    .wcover { display: block; position: relative; width: 100%; aspect-ratio: 16/10; overflow: hidden; background: #101010; }
    .wcover img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity .3s; }
    .wcover video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity .4s; z-index: 1; }
    .wcover.playing video { opacity: 1; }
    .wname { display: block; margin-top: 14px; font-size: clamp(16px, 1.6vw, 22px); font-weight: 400; color: var(--headline); letter-spacing: .01em; }
    .wcard:hover .wname { opacity: .6; }
    @media (max-width: 700px) { .wgrid { grid-template-columns: 1fr; } }
  </style>

  <script is:inline src="https://cdn.jsdelivr.net/npm/hls.js@1/dist/hls.min.js"></script>
  <script is:inline>
    // Video covers: lazy HLS autoplay in view (homepage quality)
    document.addEventListener('DOMContentLoaded', function () {
      if (!('IntersectionObserver' in window)) return;
      var io = new IntersectionObserver(function (es) {
        es.forEach(function (e) {
          var v = e.target.querySelector('video[data-hls], video[data-mp4]');
          if (!v) return;
          if (e.isIntersecting) {
            if (!v.dataset.started) {
              v.dataset.started = '1';
              if (v.dataset.mp4) {
                v.src = v.dataset.mp4;
              } else {
                var src = v.dataset.hls;
                if (window.Hls && window.Hls.isSupported()) {
                  var h = new window.Hls({ autoStartLoad: true, maxBufferLength: 8 });
                  h.loadSource(src); h.attachMedia(v);
                } else { v.src = src; }
              }
            }
            var p = v.play(); if (p && p.catch) p.catch(function () {});
            e.target.classList.add('playing');
          } else { v.pause(); }
        });
      }, { rootMargin: '300px 0px' });
      document.querySelectorAll('.wcover').forEach(function (c) {
        if (c.querySelector('video[data-hls]')) io.observe(c);
      });
    });
  </script>

  <div class="work-index">
    <div class="wgrid">
      {entries.map((e) => (
        <a class="wcard" href={`/work/${e.slug}`} aria-label={e.name}>
          <span class="wcover">
            {e.cover && <img src={e.cover} alt={e.name} decoding="async" loading="lazy"
              onerror="if(this.src.includes('thumbnail.gif')){this.onerror=null;this.src=this.src.split('/thumbnails/')[0]+'/thumbnails/thumbnail.jpg?width=900';}" />}
            {(e.hls || e.mp4) && <>
              <img src={e.poster} alt={e.name} decoding="async" loading="lazy" />
              {e.hls
                ? <video muted loop playsinline preload="none" data-hls={e.hls}></video>
                : <video muted loop playsinline preload="none" data-mp4={e.mp4}></video>}
            </>}
          </span>
          <span class="wname">{e.name}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
