---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';

// Asset hosts.
// Everything is served through Cloudinary (cloud `dvyflhlls`) EXCEPT the 3 heavy
// pit-stop gifs: they are 17-20 MB each, over Cloudinary's free-plan limit, so they
// can't be stored, fetched, or transcoded there. They stay on the Squarespace CDN
// until MP4 versions are provided (then host them as Cloudinary videos like MainEdit).
//
//   'cl'    : stored Cloudinary asset (uploaded), delivered + auto-optimised
//   'fetch' : Cloudinary fetch of a Squarespace URL (served + cached by Cloudinary CDN)
//   'sqgif' : raw Squarespace gif (the 3 oversized loops only)
//   'vid'   : stored Cloudinary video
const CL = 'https://res.cloudinary.com/dvyflhlls/';

const clImg = (id: string, w: number) => `${CL}image/upload/f_auto,q_auto,w_${w}/${id}`;
const clSet = (id: string) => [800, 1400, 2000].map((w) => `${clImg(id, w)} ${w}w`).join(', ');
const CF_SUB = 'customer-p97i3zrfuq59b5ur.cloudflarestream.com';
const cfPoster = (id: string) => `https://${CF_SUB}/${id}/thumbnails/thumbnail.jpg?height=900`;
const cfEmbed = (id: string) => `https://${CF_SUB}/${id}/iframe?autoplay=true&muted=true&loop=true&controls=false&preload=metadata`;
const clVid = (id: string) => `${CL}video/upload/q_auto/f_auto/${id}.mp4`;
const clPoster = (id: string) => `${CL}video/upload/so_0,f_auto,q_auto,w_800/${id}.jpg`;

type Item =
  | { t: 'cl'; id: string }
  | { t: 'clgif'; id: string }
  | { t: 'fetch'; u: string }
  | { t: 'cf'; id: string }
  | { t: 'vid'; id: string };

type Row = { cols: number; ar: number; feature?: boolean; items: Item[] };

const rows: Row[] = [
  { cols: 3, ar: 0.82, items: [
    { t: 'vid', id: 'RED_jvthwt' },
    { t: 'cl', id: 'floyd_hero_v14' },
    { t: 'cl', id: 'floyd_hero_v302' },
  ]},
  { cols: 2, ar: 0.80, items: [
    { t: 'cl', id: 'STILL_HERO_GOLD_V2.25_gmuy8p' },
    { t: 'cl', id: 'STILL_HERO_GOLD_V2.16_yeg33y' },
  ]},
  { cols: 4, ar: 0.56, feature: true, items: [
    { t: 'cf', id: 'c3a8515a8960a1cfcf4c182534ad17f5' },
    { t: 'vid', id: 'PIT_STOP_HERO_GOLD_W-REDtoBLUE_9.16_V003_lldbov' },
    { t: 'vid', id: 'BLUE_PIT_9.16_Web_auqt06' },
    { t: 'vid', id: 'MainEdit_122_wicm8j' },
  ]},
  { cols: 3, ar: 0.82, items: [
    { t: 'cl', id: 'floyd_hero_v41_0025' },
    { t: 'cl', id: 'migrated/STILL_HERO_GOLD_V41_0021-min' },
    { t: 'cl', id: 'RACE_tp0zuo' },
  ]},
  { cols: 3, ar: 1.02, items: [
    { t: 'cl', id: 'migrated/HERO_SHOT_WHEEL_ONLY_V0012.4' },
    { t: 'cl', id: 'migrated/HERO_SHOT_WHEEL_ONLY_V0017.10' },
    { t: 'cl', id: 'migrated/HERO_SHOT_WHEEL_ONLY_V0012.8' },
  ]},
  { cols: 3, ar: 0.82, items: [
    { t: 'cl', id: 'migrated/e' },
    { t: 'cl', id: 'migrated/HERO_SHOT_WHEEL_ONLY_V0018.15' },
    { t: 'cl', id: 'migrated/HERO_SHOT_WHEEL_ONLY_V0018.16' },
  ]},
  { cols: 3, ar: 0.82, items: [
    { t: 'cl', id: 'HERO_SHOT_WHEEL_ONLY_V0039.3_2_s1b1qx' },
    { t: 'cl', id: 'migrated/240622_wheels_as_bubbles' },
    { t: 'cl', id: 'migrated/STILL_HERO_GOLD_V006_2' },
  ]},
  { cols: 2, ar: 0.82, items: [
    { t: 'cl', id: 'migrated/TREE' },
    { t: 'cl', id: 'migrated/Screenshot_2024-12-27_at_14.08.02' },
  ]},
  { cols: 3, ar: 0.5625, items: [
    { t: 'vid', id: 'PILE_WHEELS_lqurec' },
    { t: 'vid', id: 'SCROLL_htffzh' },
    { t: 'vid', id: 'ROLL_WHEELS_d2uhvv' },
  ]},
];
---

<BaseLayout title="Floyd" activePage="work">
  <style>
    /* Break out of the centered .page wrapper so the gallery runs near the edges. */
    .floyd { width: 100vw; margin-left: calc(50% - 50vw); }

    .work-gallery {
      max-width: 2200px;
      margin: 0 auto;
      padding: clamp(8px, 2vw, 32px) clamp(10px, 3vw, 56px) 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .work-row {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(var(--cols), 1fr);
    }
    .work-cell {
      position: relative;
      aspect-ratio: var(--ar);
      overflow: hidden;
      background: #141414;
    }
    .work-cell img,
    .work-cell video,
    .work-cell iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      border: 0;
      display: block;
    }
    .work-cell.is-video video { opacity: 0; transition: opacity 0.4s ease; }
    .work-cell.is-video.playing video { opacity: 1; }

    /* Write-up */
    .work-writeup {
      max-width: 2200px;
      margin: 0 auto;
      padding: clamp(64px, 9vw, 150px) clamp(10px, 3vw, 56px) clamp(40px, 6vw, 90px);
      display: flex;
      gap: 0;
    }
    .work-writeup-left {
      width: var(--left-col);
      min-width: var(--left-col);
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding-top: 2px;
    }
    .label { font-size: 11px; line-height: 1; color: var(--label); }
    .work-writeup-right {
      flex: 1;
      max-width: 640px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .work-writeup-right p {
      font-size: 14px;
      line-height: 1.5;
      color: var(--body);
      text-wrap: pretty;
    }

    /* Project pager (prev/next). Floyd is the first project, so only Next shows. */
    .work-pager {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      max-width: 2200px;
      margin: 0 auto;
      padding: clamp(64px, 11vw, 170px) clamp(10px, 3vw, 56px);
    }
    .pager-link {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      font-size: clamp(26px, 4.2vw, 44px);
      line-height: 1;
      color: var(--headline);
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .pager-link:hover { opacity: 0.55; }
    .pager-chev { width: 0.5em; height: 0.5em; flex: none; }

    @media (max-width: 768px) {
      .work-row { grid-template-columns: 1fr; }
      .work-writeup { flex-direction: column; gap: 16px; }
      .work-writeup-left { width: auto; min-width: auto; flex-direction: row; gap: 8px; }
      .work-writeup-right { max-width: 100%; }
      .pager-link { font-size: 24px; }
    }
  </style>

  <div class="floyd">
    <div class="work-gallery">
      {rows.map((row) => (
        <div class:list={["work-row", { feature: row.feature }]} style={`--cols:${row.cols};--ar:${row.ar}`}>
          {row.items.map((m) => {
            if (m.t === 'cl') {
              return (
                <div class="work-cell">
                  <img src={clImg(m.id, 1400)} srcset={clSet(m.id)} sizes="(max-width:768px) 100vw, 40vw" alt="" decoding="async" loading="lazy" />
                </div>
              );
            }
            if (m.t === 'cf') {
              return (
                <div class="work-cell is-video">
                  <img class="poster" src={cfPoster(m.id)} alt="" decoding="async" loading="lazy" />
                  <iframe data-embed={cfEmbed(m.id)} loading="lazy" allow="autoplay; fullscreen" title="Floyd"></iframe>
                </div>
              );
            }
            if (m.t === 'clgif') {
              // Animated gif stored on Cloudinary; the free plan blocks transforms on it, so deliver raw.
              return <div class="work-cell"><img src={`${CL}image/upload/${m.id}`} alt="" decoding="async" loading="lazy" /></div>;
            }
            return (
              <div class="work-cell is-video">
                <img class="poster" src={clPoster(m.id)} alt="" decoding="async" loading="lazy" />
                <video muted loop playsinline preload="none" data-src={clVid(m.id)}></video>
              </div>
            );
          })}
        </div>
      ))}
    </div>

    <section class="work-writeup">
      <div class="work-writeup-left">
        <span class="label">Client: Floyd</span>
        <span class="label">Concept &amp; CGI: Gast Studio</span>
      </div>
      <div class="work-writeup-right">
        <p>A broken wheel is one of the fastest ways to make a suitcase useless. Floyd fixed that at the product level: the wheels come off and swap, the same way skateboard wheels do. The problem was that almost no one knew it. The feature was there, but the swap had never been shown clearly enough for people to get it.</p>
        <p>Our job was to make that obvious. We built the campaign around a pit stop. A wheel that has done its kilometers gets pulled and replaced in seconds, fast, mechanical, satisfying.</p>
        <p>It became the most viewed video on the studio's Instagram for a long time. Other brands reached out to Floyd about partnerships, the project turned into more work together, and it brought us referrals to new clients. Floyd came back to refresh it twice more with new colors and backgrounds. Running the same idea three times tells you how well it worked.</p>
      </div>
    </section>

    <nav class="work-pager">
      <a class="pager-link" href="/work/swarovski-x-ariana-grande">
        Swarovski x Ariana Grande
        <svg class="pager-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 5 16 12 9 19"/></svg>
      </a>
    </nav>
  </div>

  <script>
    const cells = document.querySelectorAll('.work-cell.is-video');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          const cell = e.target as HTMLElement;
          const v = cell.querySelector('video') as HTMLVideoElement;
          if (!v) {
            // Cloudflare Stream cell: mount the iframe once, when near view.
            const f = cell.querySelector('iframe[data-embed]') as HTMLIFrameElement;
            if (f && e.isIntersecting && !f.src) f.src = f.dataset.embed || '';
            return;
          }
          if (e.isIntersecting) {
            if (!v.src) v.src = v.dataset.src || '';
            const p = v.play();
            if (p && p.catch) p.catch(() => {});
            cell.classList.add('playing');
          } else {
            v.pause();
          }
        });
      }, { rootMargin: '200px 0px' });
      cells.forEach((c) => io.observe(c));
    } else {
      cells.forEach((c) => {
        const v = c.querySelector('video') as HTMLVideoElement;
        v.src = v.dataset.src || '';
        v.autoplay = true;
        if (v.play) v.play();
        c.classList.add('playing');
      });
    }
  </script>
</BaseLayout>
