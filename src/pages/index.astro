---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

// Homepage — renders /layout.json (the manifest saved by Grid Lab, 💾 Save)
// with the lab's own packer, ported read-only in /public/home-grid.js.
// To update the homepage design: curate in Grid Lab → Save → copy
// CODE/home-grid/layout.json to public/layout.json → push.
---

<BaseLayout title="CGI & Creative Direction Studio, Amsterdam">
  <style is:global>
    /* full-bleed board (escapes .page max-width), same geometry as the lab */
    .home-wrap { width: 100vw; margin-left: calc(50% - 50vw); }
    #board { position: relative; margin: 14px 16px 60px; }

    #board .it {
      position: absolute; display: block; overflow: hidden; background: #111;
      background-size: cover; background-position: center;
      text-decoration: none;
    }
    #board .it img, #board .it video {
      position: absolute; display: block; pointer-events: none; max-width: none;
    }
    #board .it img { opacity: 0; transition: opacity .35s ease; }
    #board .it.ld img { opacity: 1; }
    #board .it video { opacity: 0; transition: opacity .4s ease; z-index: 1; }
    #board .it.playing video { opacity: 1; }

    /* hover project title (Grid Lab v2.6: slide up from bottom-left, auto-contrast) */
    #board .it .ttl {
      position: absolute; left: 10px; bottom: 9px; z-index: 2; pointer-events: none;
      font: 400 12px/1.3 -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
      color: rgba(228,228,228,.95); letter-spacing: .03em;
      opacity: 0; transform: translateY(12px);
      transition: opacity .28s ease, transform .34s cubic-bezier(.2,.7,.3,1);
    }
    #board .it .ttl.dark { color: rgba(70,70,70,.95); }
    #board .it:hover .ttl { opacity: 1; transform: translateY(0); }

    /* failure guard: an asset that errors shows a small red note */
    #board .it.err::after {
      content: 'MEDIA MISSING'; position: absolute; bottom: 6px; left: 6px; z-index: 3;
      background: rgba(127,29,29,.9); color: #fecaca;
      font: 700 8px/1 ui-monospace, Menlo, monospace; letter-spacing: .08em;
      padding: 4px 6px; border-radius: 3px; pointer-events: none;
    }
  </style>

  <div class="home-wrap">
    <div id="board"></div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/hls.js@1/dist/hls.min.js"></script>
  <script is:inline src="/home-grid.js"></script>
</BaseLayout>
