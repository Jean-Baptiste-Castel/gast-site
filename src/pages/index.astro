---

<BaseLayout title="CGI & Creative Direction Studio, Amsterdam">
  <style>
    .home { width: 100vw; margin-left: calc(50% - 50vw); padding: 0 clamp(10px, 3vw, 56px) clamp(40px, 6vw, 90px); }
    .home-grid { display: flex; gap: 10px; max-width: 2200px; margin: 0 auto; align-items: flex-start; }
    .home-col { flex: 1; display: flex; flex-direction: column; gap: 10px; min-width: 0; }
    .home-tile { display: block; position: relative; overflow: hidden; background: #141414; line-height: 0; }
    .home-tile img { width: 100%; height: auto; display: block; }
    .home-tile video { width: 100%; aspect-ratio: 9 / 16; object-fit: cover; display: block; }
    .home-tile .poster { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .home-tile.is-video { aspect-ratio: 9 / 16; }
    .home-tile.is-video video { position: absolute; inset: 0; height: 100%; opacity: 0; transition: opacity 0.4s ease; }
    .home-tile.is-video.playing video { opacity: 1; }

    /* Migration aid: keep every tile a visible labeled block (remove when migration done) */
    .home-tile { min-height: 200px; }
    .tile-label {
      position: absolute; left: 0; right: 0; bottom: 0; z-index: 3;
      padding: 6px 8px;
      font-size: 11px; line-height: 1.3; font-weight: 400;
      color: #fff; background: rgba(0,0,0,0.6);
      word-break: break-all; pointer-events: none;
    }
    .tile-label.needs { background: rgba(120,20,20,0.78); }
    .tile-label .mp4 {
      display: inline-block; margin-right: 6px; padding: 1px 5px;
      font-size: 9px; font-weight: 700; letter-spacing: 0.04em;
      background: #ff3b30; color: #fff; border-radius: 2px; vertical-align: middle;
    }
  </style>

  <div class="home">
    <div class="home-grid" id="home-grid">
      {tiles.map((m) => (
        <a class:list={["home-tile", { 'is-video': m.t === 'vid' }]} href={projectUrl(m.p)} aria-label={m.p}>
          {m.t === 'vid' && (
            <>
              <img class="poster" src={clPoster(m.id)} alt="" decoding="async" loading="lazy" />
              <video muted loop playsinline preload="none" data-src={clVid(m.id)}></video>
            </>
          )}
          {m.t === 'cl' && (
            <img src={clImg(m.id, 800)} srcset={clSet(m.id)} sizes="(max-width:700px) 50vw, 25vw" alt="" decoding="async" loading="lazy" />
          )}
          {m.t === 'sq' && (
            m.u.endsWith('.gif')
              ? <img src={`${SQ}${m.u}`} alt="" decoding="async" loading="lazy" />
              : <img src={fImg(m.u, 800)} srcset={fSet(m.u)} sizes="(max-width:700px) 50vw, 25vw" alt="" decoding="async" loading="lazy" />
          )}
          <span class:list={["tile-label", { needs: needsMp4(m) }]}>
            {needsMp4(m) && <b class="mp4">NEEDS MP4</b>}
            {tileName(m)}
          </span>
        </a>
      ))}
    </div>
  </div>

  <script>
    const grid = document.getElementById('home-grid');
    const allTiles = Array.from(grid ? grid.querySelectorAll('.home-tile') : []);

    function columnCount() {
      const w = window.innerWidth;
      if (w < 700) return 2;
      if (w < 1100) return 3;
      return 4;
    }

    let current = 0;
    function layout() {
      if (!grid) return;
      const n = columnCount();
      if (n === current) return;
      current = n;
      grid.innerHTML = '';
      const cols = [];
      for (let i = 0; i < n; i++) {
        const c = document.createElement('div');
        c.className = 'home-col';
        cols.push(c);
        grid.appendChild(c);
      }
      // round-robin keeps the original reading order across columns
      allTiles.forEach((t, i) => cols[i % n].appendChild(t));
    }
    layout();
    let rt;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(layout, 150); });

    // lazy autoplay videos
    const vids = document.querySelectorAll('.home-tile.is-video');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          const cell = e.target as HTMLElement;
          const v = cell.querySelector('video') as HTMLVideoElement;
          if (!v) return;
          if (e.isIntersecting) {
            if (!v.src) v.src = v.dataset.src || '';
            const p = v.play();
            if (p && p.catch) p.catch(() => {});
            cell.classList.add('playing');
          } else {
            v.pause();
          }
        });
      }, { rootMargin: '300px 0px' });
      vids.forEach((c) => io.observe(c));
    }
  </script>
</BaseLayout>
