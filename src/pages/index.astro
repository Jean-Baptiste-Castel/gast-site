---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

// Home portfolio grid, rebuilt from the Squarespace home in exact tile order.
// Asset types:
//   vid = stored Cloudinary video (already migrated)
//   cl  = stored Cloudinary image (already migrated)
//   sq  = pulled from Squarespace THROUGH Cloudinary fetch (temporary; replace with
//         your MP4 / a stored copy before turning Squarespace off)
const SQ = 'https://images.squarespace-cdn.com/content/v1/6397a67a7842513d84ffeded/';
const CL = 'https://res.cloudinary.com/dvyflhlls/';

const fImg = (p: string, w: number) => `${CL}image/fetch/f_auto,q_auto,w_${w}/${SQ}${p}`;
const fSet = (p: string) => [500, 800, 1200].map((w) => `${fImg(p, w)} ${w}w`).join(', ');
const clImg = (id: string, w: number) => `${CL}image/upload/f_auto,q_auto,w_${w}/${id}`;
const clSet = (id: string) => [500, 800, 1200].map((w) => `${clImg(id, w)} ${w}w`).join(', ');
const clVid = (id: string) => `${CL}video/upload/q_auto/f_auto/${id}.mp4`;
const clPoster = (id: string) => `${CL}video/upload/so_0,f_auto,q_auto,w_600/${id}.jpg`;

type Tile =
  | { t: 'vid'; p: string; id: string }
  | { t: 'cl'; p: string; id: string }
  | { t: 'sq'; p: string; u: string };

const projectUrl = (p: string) => `https://www.gast.studio/work/${p}`;

// Migration aid: show each tile's source filename so files are easy to find/match.
const tileName = (m: Tile) => m.t === 'sq'
  ? decodeURIComponent(m.u.split('/').pop() || '').replace(/\+/g, ' ')
  : m.id;
const needsMp4 = (m: Tile) => m.t === 'sq' && m.u.endsWith('.gif');

const tiles: Tile[] = [
