// Logo scroll: never-stop smooth auto-scroll + drag + trackpad
(function() {
  var container = document.getElementById('gaLogoScroll');
  var track = document.getElementById('gaLogoTrack');
  if (!container || !track) return;

  var baseSpeed = 0.5;
  var minSpeed = 0.15;
  var currentSpeed = baseSpeed;
  var targetSpeed = baseSpeed;
  var isDragging = false;
  var dragStartX = 0;
  var dragScrollStart = 0;
  var lastDragX = 0;
  var dragVelocity = 0;
  var resumeTimer = null;
  var interacting = false;
  var lastWheelTime = 0;

  function getHalfWidth() {
    return track.scrollWidth / 2;
  }

  function wrapScroll() {
    var half = getHalfWidth();
    if (half <= 0) return;
    while (container.scrollLeft >= half) {
      container.scrollLeft -= half;
    }
    while (container.scrollLeft < 0) {
      container.scrollLeft += half;
    }
  }

  function step() {
    currentSpeed += (targetSpeed - currentSpeed) * 0.05;
    if (!isDragging && Math.abs(dragVelocity) > 0.1) {
      container.scrollLeft -= dragVelocity;
      dragVelocity *= 0.94;
    } else if (!isDragging) {
      dragVelocity = 0;
    }
    if (isDragging) {
      container.scrollLeft += minSpeed;
    } else {
      container.scrollLeft += Math.max(currentSpeed, minSpeed);
    }
    wrapScroll();
    requestAnimationFrame(step);
  }
  requestAnimationFrame(step);

  function beginInteraction() {
    interacting = true;
    targetSpeed = minSpeed;
    clearTimeout(resumeTimer);
  }

  function endInteraction() {
    interacting = false;
    clearTimeout(resumeTimer);
    resumeTimer = setTimeout(function() {
      targetSpeed = baseSpeed;
    }, 800);
  }

  container.addEventListener('mousedown', function(e) {
    isDragging = true;
    dragStartX = e.pageX;
    lastDragX = e.pageX;
    dragScrollStart = container.scrollLeft;
    dragVelocity = 0;
    beginInteraction();
    container.classList.add('is-dragging');
    e.preventDefault();
  });

  window.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    var dx = e.pageX - dragStartX;
    container.scrollLeft = dragScrollStart - dx;
    dragVelocity = e.pageX - lastDragX;
    lastDragX = e.pageX;
    wrapScroll();
  });

  window.addEventListener('mouseup', function() {
    if (isDragging) {
      isDragging = false;
      container.classList.remove('is-dragging');
      endInteraction();
    }
  });

  container.addEventListener('wheel', function(e) {
    if (Math.abs(e.deltaX) > 0) {
      container.scrollLeft += e.deltaX;
      beginInteraction();
      lastWheelTime = Date.now();
      clearTimeout(resumeTimer);
      resumeTimer = setTimeout(function() {
        if (Date.now() - lastWheelTime >= 300) {
          endInteraction();
        }
      }, 400);
      wrapScroll();
      e.preventDefault();
    }
  }, { passive: false });

  container.addEventListener('touchstart', function(e) {
    isDragging = true;
    dragStartX = e.touches[0].pageX;
    lastDragX = e.touches[0].pageX;
    dragScrollStart = container.scrollLeft;
    dragVelocity = 0;
    beginInteraction();
  }, { passive: true });

  container.addEventListener('touchmove', function(e) {
    if (!isDragging) return;
    var dx = e.touches[0].pageX - dragStartX;
    container.scrollLeft = dragScrollStart - dx;
    dragVelocity = e.touches[0].pageX - lastDragX;
    lastDragX = e.touches[0].pageX;
    wrapScroll();
  }, { passive: false });

  container.addEventListener('touchend', function() {
    isDragging = false;
    endInteraction();
  });
})();

// Email obfuscation: builds the address at runtime so scrapers can't harvest it
(function() {
  var el = document.getElementById('ga-email-link');
  if (!el) return;
  var u = 'contact';
  var d = 'gast.studio';
  var addr = u + '@' + d;
  var link = document.createElement('a');
  link.href = 'ma' + 'il' + 'to:' + addr;
  link.className = 'ga-cta-email';
  link.textContent = 'Or email directly: ' + addr;
  el.parentNode.replaceChild(link, el);
})();

  </script>
