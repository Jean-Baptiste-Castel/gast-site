---
interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} - Gast Studio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Arimo:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">
    <img src="/gast-wordmark-white.png" alt="Gast">
  </a>
  <div class="nav-links">
    <a href="/work" class:list={["nav-link", { active: activePage === 'work' }]}>Projects</a>
    <a href="https://vbxikz-33.myshopify.com" class="nav-link">Store</a>
    <a href="/about" class:list={["nav-link", { active: activePage === 'about' }]}>About</a>
    <a href="/contact" class="nav-link">Contact</a>
    <!-- reserved slot where the basket icon lives on the Shopify store,
         so nav links align pixel-perfectly across site and shop -->
    <span class="nav-cart-slot" aria-hidden="true"></span>
  </div>
  <!-- mobile hamburger (same icon as the Shopify store, right side) -->
  <button class="nav-burger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="nav-drawer">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 16" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M1 .5a.5.5 0 1 0 0 1h15.71a.5.5 0 0 0 0-1zM.5 8a.5.5 0 0 1 .5-.5h15.71a.5.5 0 0 1 0 1H1A.5.5 0 0 1 .5 8m0 7a.5.5 0 0 1 .5-.5h15.71a.5.5 0 0 1 0 1H1a.5.5 0 0 1-.5-.5"/></svg>
  </button>
</nav>
<div class="nav-drawer" id="nav-drawer" hidden>
  <a href="/work" class:list={["nav-drawer-link", { active: activePage === 'work' }]}>Projects</a>
  <a href="https://vbxikz-33.myshopify.com" class="nav-drawer-link">Store</a>
  <a href="/about" class:list={["nav-drawer-link", { active: activePage === 'about' }]}>About</a>
  <a href="/contact" class="nav-drawer-link">Contact</a>
</div>

<div class="page">
  <slot />
</div>

  <footer class="footer">
    <a href="https://www.instagram.com/gast_studio/" target="_blank" rel="noopener" aria-label="Instagram" class="social">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="2.5" width="19" height="19" rx="5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none"/></svg>
    </a>
    <a href="https://www.linkedin.com/in/jean-baptiste-castel-b08a0b160/" target="_blank" rel="noopener" aria-label="LinkedIn" class="social">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5 2.5 2.5 0 01.02-5zM3 9h4v12H3zM10 9h3.8v1.64h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.76V21h-4v-5.1c0-1.22-.02-2.78-1.7-2.78-1.7 0-1.96 1.32-1.96 2.69V21h-4z"/></svg>
    </a>
    <a href="https://www.are.na/jean-baptiste-castel/channels" target="_blank" rel="noopener" aria-label="Are.na" class="social social-arena">&#10038;&#10038;</a>
  </footer>

<script is:inline>
  (function () {
    var b = document.querySelector('.nav-burger');
    var d = document.getElementById('nav-drawer');
    if (!b || !d) return;
    function set(open) {
      if (open) { d.removeAttribute('hidden'); b.setAttribute('aria-expanded', 'true'); document.documentElement.classList.add('nav-open'); }
      else { d.setAttribute('hidden', ''); b.setAttribute('aria-expanded', 'false'); document.documentElement.classList.remove('nav-open'); }
    }
    b.addEventListener('click', function () { set(d.hasAttribute('hidden')); });
    d.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', function () { set(false); }); });
    window.addEventListener('resize', function () { if (window.innerWidth >= 990) set(false); });
  })();
</script>

</body>
</html>
